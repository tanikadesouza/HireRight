# =============================================================================
# .gitignore — generic baseline for Supabase + Next.js / Vite / similar projects
# =============================================================================
# This is the template copied to a fresh project's root during Phase 0.
# Adapt as your stack diverges, but DO NOT remove the env-files block.

# --- Secrets (never commit) ---------------------------------------------------
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test
# Committed templates only — these are safe to track:
!.env.example
!.env.test.example

# --- Node / package managers --------------------------------------------------
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# --- Frameworks ---------------------------------------------------------------
# Next.js
.next/
out/
next-env.d.ts
# Vite
dist/
dist-ssr/
.vite/
# Remix / SvelteKit
build/
.svelte-kit/

# --- Builds & coverage --------------------------------------------------------
*.tsbuildinfo
coverage/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Editor / OS --------------------------------------------------------------
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
.DS_Store
Thumbs.db

# --- Supabase CLI -------------------------------------------------------------
# Local Supabase state
supabase/.branches
supabase/.temp
# Generated runnable seed (created by scripts/create-test-users.mjs at runtime)
supabase/seed.runnable.sql

# --- Test artifacts -----------------------------------------------------------
# Playwright auth state (created at test-run time, never commit)
tests/.auth/
playwright-report/
test-results/
.playwright/

# --- Misc ---------------------------------------------------------------------
*.swp
*.swo
.cache/
supabase/functions/.env
