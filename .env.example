# =============================================================================
# .env.example — generic baseline template
# =============================================================================
# This is the FALLBACK template copied during Phase 0. If your project came
# from the PRD generator, prefer the project-specific `env-templates.md`
# artifact (it adds every integration credential from PRD §4 with comments).
#
# Copy to .env.local and fill in real values. Never commit .env.local.
# =============================================================================

# --- Frontend (bundled into client JS — must NOT contain secrets) ------------
# Used by: src/lib/supabase/client.ts (or equivalent SSR client)
# Adapt the prefix for your framework:
#   Next.js   → NEXT_PUBLIC_*
#   Vite      → VITE_*
#   SvelteKit → PUBLIC_*
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Bootstrap script + local admin scripts ----------------------------------
# Used by: scripts/create-test-users.mjs and any local admin .mjs scripts
# These mirror the NEXT_PUBLIC_* values for the supabase-js admin client
# (no NEXT_PUBLIC_ prefix because they're server-only and must never be bundled).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Supabase CLI ------------------------------------------------------------
# Used by: supabase CLI for `supabase db push`, `supabase functions deploy`,
# `supabase secrets set`. Generate at https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=

# --- Third-party integrations from PRD §4 -----------------------------------
# Add one row per integration's `Credential name` (see PRD §4 tables).
# Examples (delete the ones you don't use):
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# RESEND_API_KEY=
