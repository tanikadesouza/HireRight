# =============================================================================
# .env.test.example — test-user credentials template
# =============================================================================
# Used by:
#   - scripts/create-test-users.mjs (creates these users via Supabase Auth Admin)
#   - tests/abuse-test.ts (signs in as User A and User B for cross-isolation tests)
#   - playwright.config.ts (loaded automatically if .env.test exists)
#
# Copy to .env.test and fill in unique emails + strong passwords.
# Never commit .env.test.
# =============================================================================

# --- Required: two regular test users for abuse tests ------------------------
TEST_USER_A_EMAIL=
TEST_USER_A_PASSWORD=
TEST_USER_B_EMAIL=
TEST_USER_B_PASSWORD=

# --- Optional: owner account for single-user mode tests ----------------------
# Uncomment if your app's User Model requires an owner (PRD §1).
# TEST_OWNER_EMAIL=
# TEST_OWNER_PASSWORD=

# --- Optional: multi-user collaborative -------------------------------------
# Uncomment if PRD §1 says multi-user collaborative — these seed an org.
# TEST_ORG_NAME=Acme Test
# TEST_ADMIN_EMAIL=
# TEST_ADMIN_PASSWORD=
